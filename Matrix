#include <stdio.h>

// Define a maximum size for the static arrays
#define MAX 10

// Function prototypes
void inputMatrix(int matrix[MAX][MAX], int rows, int cols);
void displayMatrix(int matrix[MAX][MAX], int rows, int cols);
void addMatrices(int A[MAX][MAX], int B[MAX][MAX], int result[MAX][MAX], int rows, int cols);
void multiplyMatrices(int A[MAX][MAX], int B[MAX][MAX], int result[MAX][MAX], int r1, int c1, int c2);
void transposeMatrix(int matrix[MAX][MAX], int result[MAX][MAX], int rows, int cols);

int main() {
    int A[MAX][MAX], B[MAX][MAX], result[MAX][MAX];
    int r1, c1, r2, c2;

    // --- Input for Matrix A ---
    printf("Enter rows and columns for Matrix A (max %d): ", MAX);
    scanf("%d %d", &r1, &c1);
    printf("Enter elements for Matrix A:\n");
    inputMatrix(A, r1, c1);

    // --- Input for Matrix B ---
    printf("\nEnter rows and columns for Matrix B (max %d): ", MAX);
    scanf("%d %d", &r2, &c2);
    printf("Enter elements for Matrix B:\n");
    inputMatrix(B, r2, c2);

    // --- Display Original Matrices ---
    printf("\n--- Matrix A ---\n");
    displayMatrix(A, r1, c1);
    printf("\n--- Matrix B ---\n");
    displayMatrix(B, r2, c2);

    // --- 1. Matrix Addition ---
    printf("\n=========================================\n");
    if (r1 == r2 && c1 == c2) {
        addMatrices(A, B, result, r1, c1);
        printf("Result of Addition (A + B):\n");
        displayMatrix(result, r1, c1);
    } else {
        printf("Addition Error: Matrices must have identical dimensions.\n");
    }

    // --- 2. Matrix Multiplication ---
    printf("\n=========================================\n");
    if (c1 == r2) {
        multiplyMatrices(A, B, result, r1, c1, c2);
        printf("Result of Multiplication (A * B):\n");
        displayMatrix(result, r1, c2); // Result is size r1 x c2
    } else {
        printf("Multiplication Error: Columns of A (%d) must match Rows of B (%d).\n", c1, r2);
    }

    // --- 3. Matrix Transpose ---
    printf("\n=========================================\n");
    printf("Transpose of Matrix A:\n");
    transposeMatrix(A, result, r1, c1);
    displayMatrix(result, c1, r1); // Dimensions swap for transpose
     printf("Transpose of Matrix B:\n");
    transposeMatrix(B, result, r2, c2);
    displayMatrix(result, c2, r2);

    return 0;
}

// Function to read matrix inputs
void inputMatrix(int matrix[MAX][MAX], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            printf("Element [%d][%d]: ", i, j);
            scanf("%d", &matrix[i][j]);
        }
    }
}

// Function to print a matrix in a clean grid format
void displayMatrix(int matrix[MAX][MAX], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            printf("%5d ", matrix[i][j]);
        }
        printf("\n");
    }
}

// Function to perform matrix addition
void addMatrices(int A[MAX][MAX], int B[MAX][MAX], int result[MAX][MAX], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            result[i][j] = A[i][j] + B[i][j];
        }
    }
}

// Function to perform matrix multiplication
void multiplyMatrices(int A[MAX][MAX], int B[MAX][MAX], int result[MAX][MAX], int r1, int c1, int c2) {
    // Safely zero out the result array first
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            result[i][j] = 0;
        }
    }

    // Classic row-by-column dot product multiplication loops
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            for (int k = 0; k < c1; k++) {
                result[i][j] += A[i][k] * B[k][j];
            }
        }
    }
}

// Function to transpose a matrix
void transposeMatrix(int matrix[MAX][MAX], int result[MAX][MAX], int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            result[j][i] = matrix[i][j]; // Notice the flipped indices
        }
    }
}