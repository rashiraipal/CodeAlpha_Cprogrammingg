#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define FILE_NAME "students.dat"

// Structure to represent a student record
typedef struct {
    int rollNo;
    char name[50];
    float gpa;
} Student;

// Function prototypes
void addRecord();
void displayRecords();
void searchRecord();
void updateRecord();
void deleteRecord();

int main() {
    int choice;

    while (1) {
        printf("\n=========================================");
        printf("\n       STUDENT RECORD MANAGEMENT         ");
        printf("\n=========================================");
        printf("\n1. Add Student Record");
        printf("\n2. Display All Records");
        printf("\n3. Search Student Record");
        printf("\n4. Update Student Record");
        printf("\n5. Delete Student Record");
        printf("\n6. Exit");
        printf("\n=========================================");
        printf("\nEnter your choice (1-6): ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addRecord(); break;
            case 2: displayRecords(); break;
            case 3: searchRecord(); break;
            case 4: updateRecord(); break;
            case 5: deleteRecord(); break;
            case 6: 
                printf("\nExiting program. Goodbye!\n");
                exit(0);
            default: 
                printf("\nInvalid choice! Please try again.\n");
        }
    }
    return 0;
}

// 1. Function to add a record (Append to File)
void addRecord() {
    FILE *fp = fopen(FILE_NAME, "ab"); // Open in append-binary mode
    if (fp == NULL) {
        printf("\nError opening file!\n");
        return;
    }

    Student s;
    printf("\nEnter Roll Number: ");
    scanf("%d", &s.rollNo);
    getchar(); // Clear the newline character from the buffer

    printf("Enter Name: ");
    fgets(s.name, sizeof(s.name), stdin);
    s.name[strcspn(s.name, "\n")] = 0; // Remove the trailing newline character

    printf("Enter GPA: ");
    scanf("%f", &s.gpa);

    // Write the entire structure block to the file
    fwrite(&s, sizeof(Student), 1, fp);
    fclose(fp);

    printf("\nRecord added successfully!\n");
}

// 2. Function to display all records
void displayRecords() {
    FILE *fp = fopen(FILE_NAME, "rb"); // Open in read-binary mode
    if (fp == NULL) {
        printf("\nNo records found (or file doesn't exist yet).\n");
        return;
    }

    Student s;
    printf("\n---------------------------------------------------");
    printf("\n%-10s %-30s %-5s", "Roll No", "Name", "GPA");
    printf("\n---------------------------------------------------");

    // Read structure blocks until the end of file (EOF)
    while (fread(&s, sizeof(Student), 1, fp) == 1) {
        printf("\n%-10d %-30s %-5.2f", s.rollNo, s.name, s.gpa);
    }
    printf("\n---------------------------------------------------\n");
    fclose(fp);
}

// 3. Function to search for a specific record by Roll Number
void searchRecord() {
    FILE *fp = fopen(FILE_NAME, "rb");
    if (fp == NULL) {
        printf("\nNo records found.\n");
        return;
    }

    int targetRoll, found = 0;
    Student s;

    printf("\nEnter Roll Number to search: ");
    scanf("%d", &targetRoll);

    while (fread(&s, sizeof(Student), 1, fp) == 1) {
        if (s.rollNo == targetRoll) {
            printf("\nRecord Found!");
            printf("\nRoll No: %d", s.rollNo);
            printf("\nName   : %s", s.name);
            printf("\nGPA    : %.2f\n", s.gpa);
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("\nRecord with Roll Number %d not found.\n", targetRoll);
    }
    fclose(fp);
}

// 4. Function to update an existing record
void updateRecord() {
    FILE *fp = fopen(FILE_NAME, "rb+"); // Open in read/write-binary mode
    if (fp == NULL) {
        printf("\nNo records found.\n");
        return;
    }

    int targetRoll, found = 0;
    Student s;

    printf("\nEnter Roll Number to update: ");
    scanf("%d", &targetRoll);

    while (fread(&s, sizeof(Student), 1, fp) == 1) {
        if (s.rollNo == targetRoll) {
            found = 1;
            printf("\nCurrent Record: %d | %s | %.2f\n", s.rollNo, s.name, s.gpa);

            // Get new details
            getchar(); // Clear buffer
            printf("Enter New Name: ");
            fgets(s.name, sizeof(s.name), stdin);
            s.name[strcspn(s.name, "\n")] = 0;

            printf("Enter New GPA: ");
            scanf("%f", &s.gpa);

            // Move the file pointer back to the start of this specific record
            fseek(fp, -sizeof(Student), SEEK_CUR);

            // Overwrite the old record with the updated structure data
            fwrite(&s, sizeof(Student), 1, fp);
            printf("\nRecord updated successfully!\n");
            break;
        }
    }

    if (!found) {
        printf("\nRecord with Roll Number %d not found.\n", targetRoll);
    }
    fclose(fp);
}

// 5. Function to delete a record
void deleteRecord() {
    FILE *fp = fopen(FILE_NAME, "rb");
    if (fp == NULL) {
        printf("\nNo records found.\n");
        return;
    }

    // Open a temporary file to copy over all records EXCEPT the one to delete
    FILE *tempFp = fopen("temp.dat", "wb");
    if (tempFp == NULL) {
        printf("\nError processing deletion.\n");
        fclose(fp);
        return;
    }

    int targetRoll, found = 0;
    Student s;

    printf("\nEnter Roll Number to delete: ");
    scanf("%d", &targetRoll);

    while (fread(&s, sizeof(Student), 1, fp) == 1) {
        if (s.rollNo == targetRoll) {
            found = 1; // Mark found but do NOT write it to temp file
        } else {
            fwrite(&s, sizeof(Student), 1, tempFp);
        }
    }

    fclose(fp);
    fclose(tempFp);

    if (found) {
        remove(FILE_NAME);             // Delete original file
        rename("temp.dat", FILE_NAME); // Rename temp file to original name
        printf("\nRecord deleted successfully!\n");
    } else {
        remove("temp.dat"); // Clean up temp file if nothing changed
        printf("\nRecord with Roll Number %d not found.\n", targetRoll);
    }
}